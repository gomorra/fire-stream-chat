rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isParticipant() {
      return isAuth() && request.auth.uid in resource.data.participants;
    }
    function willBeParticipant() {
      return isAuth() && request.auth.uid in request.resource.data.participants;
    }

    // ── Users ────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    // Cloud Function syncPresenceToFirestore also writes
                    || request.auth == null;

      match /blockedUsers/{targetId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Key Bundles (Signal Protocol) ────────────────────────────
    match /keyBundles/{uid} {
      allow read:   if isAuth();
      allow write:  if isOwner(uid);
    }

    // ── Chats ────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read:   if isAuth()
                    && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth()
                    && request.auth.uid in resource.data.participants;
      allow delete: if isAuth()
                    && resource.data.createdBy == request.auth.uid;

      match /messages/{messageId} {
        allow read:   if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update: if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ── Calls ────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read:   if isAuth()
                    && (request.auth.uid == resource.data.callerId
                    ||  request.auth.uid == resource.data.calleeId);
      allow create: if isAuth()
                    && request.auth.uid == request.resource.data.callerId;
      allow update: if isAuth()
                    && (request.auth.uid == resource.data.callerId
                    ||  request.auth.uid == resource.data.calleeId);

      match /callerCandidates/{candidateId} {
        allow read:   if isAuth();
        allow create: if isAuth();
      }
      match /calleeCandidates/{candidateId} {
        allow read:   if isAuth();
        allow create: if isAuth();
      }
    }

    // ── Lists ────────────────────────────────────────────────────
    match /lists/{listId} {
      allow read:   if isAuth()
                    && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth()
                    && request.auth.uid in resource.data.participants;
      allow delete: if isAuth()
                    && resource.data.createdBy == request.auth.uid;

      match /history/{entryId} {
        allow read:   if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.participants;
        allow create: if isAuth()
                      && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.participants;
      }

      match /items/{itemId} {
        allow read, write: if isAuth()
                           && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.participants;
      }
    }

    // ── Invite Links ─────────────────────────────────────────────
    match /inviteLinks/{token} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }
  }
}
